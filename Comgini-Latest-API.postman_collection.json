		{
			"name": "2. Task & Activity Management",
			"item": [
				{
					"name": "List Tasks",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
						],
						"url": {
							"raw": "{{baseUrl}}/api/tasks?page=1&limit=10&status=todo&is_starred=false",
							"host": ["{{baseUrl}}"],
							"path": ["api", "tasks"],
							"query": [
								{ "key": "page", "value": "1" },
								{ "key": "limit", "value": "10" },
								{ "key": "status", "value": "todo" },
								{ "key": "is_starred", "value": "false" }
							]
						}
					}
				},
				{
					"name": "Create New Task",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" },
							{ "key": "Content-Type", "value": "application/json", "type": "text" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Quarterly Audit Preparation\",\n  \"description\": \"Collate all financial documents for the Q1 audit.\",\n  \"client_id\": 1,\n  \"company_id\": 2,\n  \"assigned_to\": 3,\n  \"priority\": \"high\",\n  \"status\": \"todo\",\n  \"due_date\": \"2026-04-15\",\n  \"estimated_hours\": 8,\n  \"category\": \"Audit\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/tasks",
							"host": ["{{baseUrl}}"],
							"path": ["api", "tasks"]
						}
					}
				},
				{
					"name": "Update Task Details",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" },
							{ "key": "Content-Type", "value": "application/json", "type": "text" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"status\": \"inprogress\",\n  \"actual_hours\": 2,\n  \"is_starred\": true\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/tasks/:id",
							"host": ["{{baseUrl}}"],
							"path": ["api", "tasks", ":id"],
							"variable": [{ "key": "id", "value": "1" }]
						}
					}
				},
				{
					"name": "Update Task Status",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" },
							{ "key": "Content-Type", "value": "application/json", "type": "text" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"status\": \"completed\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/tasks/:id/status",
							"host": ["{{baseUrl}}"],
							"path": ["api", "tasks", ":id", "status"],
							"variable": [{ "key": "id", "value": "1" }]
						}
					}
				},
				{
					"name": "Start Timer",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
						],
						"url": {
							"raw": "{{baseUrl}}/api/tasks/:id/timer/start",
							"host": ["{{baseUrl}}"],
							"path": ["api", "tasks", ":id", "timer", "start"],
							"variable": [{ "key": "id", "value": "1" }]
						}
					}
				},
				{
					"name": "Stop Timer",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" },
							{ "key": "Content-Type", "value": "application/json", "type": "text" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"notes\": \"Finished documentation part 1\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/tasks/timer/:id/stop",
							"host": ["{{baseUrl}}"],
							"path": ["api", "tasks", "timer", ":id", "stop"],
							"variable": [{ "key": "id", "value": "101" }]
						}
					}
				},
				{
					"name": "Log Call Activity",
					"request": {
						"method": "POST",
