{
	"info": {
		"_postman_id": "c4d5e6f7-a8b9-0123-cdef-456789abcdef",
		"name": "Comgini API v1 — Leads, Finance, Business, Timesheets, Time cards",
		"description": "Standalone collection: **Leads**, **Finance** (income vs expenses + payments), **Business Manager** (insurance, contracts, registrations, agreements alias), **Timesheets**, **Time cards**, plus **dropdowns**.\n\n**Auth:** Run **Login** first; token is saved to `{{token}}`.\n\n**DB:** Apply `payments_module.sql` and `time_cards_module.sql` if those tables are missing.\n\n**Base URL:** set `baseUrl` (e.g. `http://localhost:3000` or your server).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
	},
	"item": [
		{
			"name": "0. Auth",
			"item": [
				{
					"name": "Login (saves token)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const j = pm.response.json();",
									"const t = j.data && (j.data.accessToken || j.data.token);",
									"if (t) { pm.collectionVariables.set('token', t); pm.test('Token saved', () => pm.expect(t).to.be.a('string')); }",
									"else { pm.test('Login returned token', () => pm.expect(t).to.be.ok); }"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"YourPassword123!\"\n}"
						},
						"url": "{{baseUrl}}/api/v1/auth/login"
					}
				},
				{
					"name": "GET profile",
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{baseUrl}}/api/v1/auth/profile"
					}
				}
			]
		},
