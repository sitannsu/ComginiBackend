{
	"info": {
		"_postman_id": "c7e8f9a0-1111-4222-b333-444455556666",
		"name": "Comgini Secretarial + Dashboard v1",
		"description": "Bearer auth, dashboard under /api/v1, GET /api/v1/updates alias, and full Secretarial Practice API.\n\nVariables: set `baseUrl` (e.g. http://localhost:3000 or your EC2 URL). Run **Login** first — it saves `accessToken` into collection var `token`.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
	},
	"item": [
		{
			"name": "0. Auth",
			"item": [
				{
					"name": "Login (saves token)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const j = pm.response.json();",
									"const t = j.data && (j.data.accessToken || j.data.token);",
									"if (t) { pm.collectionVariables.set('token', t); pm.test('Token saved', () => pm.expect(t).to.be.a('string')); }",
									"else { pm.test('Login returned token', () => pm.expect(t).to.be.ok); }"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"YourPassword123!\"\n}"
						},
						"url": "{{baseUrl}}/api/v1/auth/login"
					}
				},
				{
					"name": "Get profile",
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{baseUrl}}/api/v1/auth/profile"
					}
				}
			]
		},
		{
			"name": "1. Dashboard (v1)",
			"item": [
				{
					"name": "GET stats",
					"request": { "method": "GET", "header": [], "url": "{{baseUrl}}/api/v1/dashboard/stats" }
				},
				{
					"name": "GET payments",
					"request": { "method": "GET", "header": [], "url": "{{baseUrl}}/api/v1/dashboard/payments" }
				},
				{
					"name": "GET income-expense",
					"request": { "method": "GET", "header": [], "url": "{{baseUrl}}/api/v1/dashboard/income-expense" }
				},
				{
					"name": "GET finance-breakdown",
					"request": { "method": "GET", "header": [], "url": "{{baseUrl}}/api/v1/dashboard/finance-breakdown" }
				},
				{
					"name": "GET updates (alias /api/v1/updates)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/updates?limit=10",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "updates"],
							"query": [{ "key": "limit", "value": "10" }]
						}
					}
				},
				{
					"name": "GET updates (nested /api/v1/dashboard/updates)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/dashboard/updates?limit=10",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "dashboard", "updates"],
							"query": [{ "key": "limit", "value": "10" }]
						}
					}
				},
				{
					"name": "GET legacy /api/updates",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/updates?limit=10",
							"host": ["{{baseUrl}}"],
							"path": ["api", "updates"],
							"query": [{ "key": "limit", "value": "10" }]
						}
					}
				}
			]
		},
		{
			"name": "2. Secretarial — Search & CSR",
			"item": [
				{
					"name": "List search reports",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/secretarial/search-reports?type=company&page=1&limit=20&search=",
							"query": [
								{ "key": "type", "value": "company", "description": "company | llp" },
								{ "key": "page", "value": "1" },
								{ "key": "limit", "value": "20" },
								{ "key": "search", "value": "" }
							]
						}
					}
				},
				{
					"name": "Create search report",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"entity_type\": \"company\",\n  \"date_of_search\": \"2026-03-31\",\n  \"srn_mca_search\": \"SRN123\",\n  \"signed_by\": \"1\",\n  \"udin\": \"\",\n  \"date_of_signing\": \"2026-03-31\",\n  \"place_of_signing\": \"Mumbai\",\n  \"cin\": \"U12345MH2020PTC123456\",\n  \"company_name\": \"Demo Pvt Ltd\",\n  \"registered_office\": \"Address\",\n  \"registration_number\": \"\",\n  \"authorized_capital\": 1000000,\n  \"paid_up_capital\": 100000,\n  \"date_of_incorporation\": \"2020-01-01\",\n  \"date_of_last_agm\": \"2025-09-30\",\n  \"date_of_last_balance_sheet\": \"2025-03-31\",\n  \"signatories\": [{ \"name_designation\": \"Director\", \"doa\": \"2020-01-01\", \"din_pan\": \"01234567\" }],\n  \"shareholders\": [{ \"name\": \"A\", \"address\": \"\", \"type\": \"equity\", \"count\": 1000, \"paid\": 10, \"total\": 10000 }],\n  \"charges\": [{ \"charge_id\": \"CH1\", \"created\": \"2021-01-01\", \"modified\": \"2021-01-01\", \"secured_amount\": 0, \"short_particulars\": \"\", \"holder_name\": \"\", \"holder_address\": \"\" }]\n}"
						},
						"url": "{{baseUrl}}/api/v1/secretarial/search-reports"
					}
				},
				{
					"name": "List CSR calculations",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/secretarial/csr-calculations?page=1&limit=20",
							"query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "20" }]
						}
					}
				},
				{
					"name": "Create CSR calculation",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"client_id\": 1,\n  \"financial_year\": \"2023-24\",\n  \"computation_data\": {\n    \"net_profit_before_tax\": [100, 110, 120, 130],\n    \"csr_expenses\": [0, 0, 0, 0],\n    \"jv_profit\": [0, 0, 0, 0],\n    \"jv_loss\": [0, 0, 0, 0],\n    \"income_tax\": [0, 0, 0, 0]\n  },\n  \"csr_spent\": 50000,\n  \"excess_carry_forward\": 0\n}"
						},
						"url": "{{baseUrl}}/api/v1/secretarial/csr-calculations"
					}
				}
			]
		},
		{
			"name": "3. Secretarial — DSC",
			"item": [
				{
					"name": "Add DSC box (spec)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{ \"name\": \"Box A\" }" },
						"url": "{{baseUrl}}/api/v1/secretarial/dsc/boxes"
					}
				},
				{
					"name": "List DSC records",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/secretarial/dsc?status=active&company_id=&group_id=&search=",
							"query": [
								{ "key": "status", "value": "active", "description": "active | expiring | expired" },
								{ "key": "company_id", "value": "" },
								{ "key": "group_id", "value": "" },
								{ "key": "search", "value": "" }
							]
						}
					}
				},
				{
					"name": "Create DSC token (legacy)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"holder_name\": \"Director Name\",\n  \"din\": \"01234567\",\n  \"company_id\": 1,\n  \"client_group\": \"\",\n  \"token_serial\": \"\",\n  \"provider\": \"\",\n  \"issue_date\": \"2025-01-01\",\n  \"expiry_date\": \"2027-01-01\",\n  \"box_location\": \"Box A\",\n  \"notes\": \"\"\n}"
						},
						"url": "{{baseUrl}}/api/v1/secretarial/dsc"
					}
				},
				{
					"name": "PATCH DSC in/out (spec)",
					"request": {
						"method": "PATCH",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{ \"availability\": \"in\", \"location\": \"Box A\" }" },
						"url": "{{baseUrl}}/api/v1/secretarial/dsc/{{dscId}}/status"
					}
				},
				{
					"name": "List DSC boxes (legacy)",
					"request": { "method": "GET", "header": [], "url": "{{baseUrl}}/api/v1/secretarial/dsc-boxes" }
				}
			]
		},
