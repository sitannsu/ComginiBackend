          "request": {
            "method": "POST",
            "header": [{ "key":"Content-Type","value":"application/json" }],
            "body": { "mode":"raw", "raw":"{\n  \"title\": \"New Lead\",\n  \"companyName\": \"ABC Pvt Ltd\",\n  \"status\": \"Discussion\",\n  \"ownerId\": 1,\n  \"source\": \"Online\",\n  \"address\": \"MG Road\",\n  \"city\": \"Bengaluru\",\n  \"state\": \"Karnataka\",\n  \"pincode\": \"560001\",\n  \"country\": \"India\",\n  \"phone\": \"9876543210\",\n  \"website\": \"https://abc.com\",\n  \"gstin\": \"29ABCDE1234F1Z5\"\n}" },
            "url": { "raw": "{{baseUrl}}/leads", "host": ["{{baseUrl}}"], "path": ["leads"] }
          }
        },
