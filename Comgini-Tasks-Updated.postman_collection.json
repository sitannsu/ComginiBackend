{
  "info": {
    "_postman_id": "comgini-tasks-updated-v1",
    "name": "Comgini Tasks Updated APIs",
    "description": "Updated Tasks APIs with star toggle, filters, and extended task fields.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://13.126.81.144:3000/api/v1" },
    { "key": "token", "value": "" },
    { "key": "taskId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Get All Tasks",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/tasks?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get Completed Tasks",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/tasks?status=completed&page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"],
              "query": [
                { "key": "status", "value": "completed" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get Starred Tasks",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/tasks?is_starred=true&page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"],
              "query": [
                { "key": "is_starred", "value": "true" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get Task by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["tasks", "{{taskId}}"]
            }
          }
        },
        {
          "name": "Create Task (Extended Fields)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.id) {",
                  "    pm.collectionVariables.set('taskId', jsonData.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"File Annual Return for Acme Corp\",\n  \"description\": \"Prepare and file AOC-4 for FY 2025-26\",\n  \"client_id\": 1,\n  \"company_id\": 1,\n  \"assigned_to\": 2,\n  \"priority\": \"high\",\n  \"status\": \"todo\",\n  \"is_starred\": true,\n  \"collaborators\": [2, 4, 5],\n  \"approver\": 3,\n  \"labels\": [\"compliance\", \"annual\", \"urgent\"],\n  \"start_date\": \"2026-03-20\",\n  \"due_date\": \"2026-03-31\",\n  \"recurring\": false,\n  \"estimated_hours\": 4,\n  \"category\": \"Annual Filing\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"]
            }
          }
        },
        {
          "name": "Toggle Task Star",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/tasks/{{taskId}}/star",
              "host": ["{{baseUrl}}"],
              "path": ["tasks", "{{taskId}}", "star"]
            }
          }
        },
        {
          "name": "Update Task (Partial)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_progress\",\n  \"assigned_to\": 4,\n  \"is_starred\": true,\n  \"labels\": [\"compliance\", \"review\"],\n  \"collaborators\": [2, 4],\n  \"approver\": 3,\n  \"start_date\": \"2026-03-20\",\n  \"due_date\": \"2026-03-31\",\n  \"estimated_hours\": 4,\n  \"actual_hours\": 2,\n  \"category\": \"Annual Filing\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["tasks", "{{taskId}}"]
            }
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["tasks", "{{taskId}}"]
            }
          }
        }
      ]
    }
  ]
}
