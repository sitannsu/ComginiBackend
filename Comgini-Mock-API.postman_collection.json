{
    "info": {
        "name": "Comgini Mock API",
        "description": "Mock API endpoints for testing without database",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Health Check",
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "{{mock_base_url}}/health",
                    "host": [
                        "{{mock_base_url}}"
                    ],
                    "path": [
                        "health"
                    ]
                }
            }
        },
        {
            "name": "Login - Test User",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "if (pm.response.code === 200) {",
                            "    var jsonData = pm.response.json();",
                            "    pm.environment.set('access_token', jsonData.data.accessToken);",
                            "    pm.environment.set('refresh_token', jsonData.data.refreshToken);",
                            "}"
                        ]
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"Test123!@#\"\n}"
                },
                "url": {
                    "raw": "{{mock_base_url}}/api/v1/auth/login",
                    "host": [
                        "{{mock_base_url}}"
                    ],
                    "path": [
                        "api",
                        "v1",
                        "auth",
                        "login"
                    ]
                }
            }
        },
        {
            "name": "Login - Admin User",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "if (pm.response.code === 200) {",
                            "    var jsonData = pm.response.json();",
                            "    pm.environment.set('access_token', jsonData.data.accessToken);",
                            "    pm.environment.set('refresh_token', jsonData.data.refreshToken);",
                            "}"
                        ]
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"email\": \"admin@comgini.com\",\n  \"password\": \"Admin123!@#\"\n}"
                },
                "url": {
                    "raw": "{{mock_base_url}}/api/v1/auth/login",
                    "host": [
                        "{{mock_base_url}}"
                    ],
                    "path": [
                        "api",
                        "v1",
                        "auth",
                        "login"
                    ]
                }
            }
        },
        {
            "name": "Login - Invalid Credentials",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"WrongPassword\"\n}"
                },
                "url": {
                    "raw": "{{mock_base_url}}/api/v1/auth/login",
                    "host": [
                        "{{mock_base_url}}"
                    ],
                    "path": [
                        "api",
                        "v1",
                        "auth",
                        "login"
                    ]
                }
            }
        },
        {
            "name": "Forgot Password",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"email\": \"test@example.com\"\n}"
                },
                "url": {
                    "raw": "{{mock_base_url}}/api/v1/auth/forgot-password",
                    "host": [
                        "{{mock_base_url}}"
                    ],
                    "path": [
                        "api",
                        "v1",
                        "auth",
                        "forgot-password"
                    ]
                }
            }
        },
        {
            "name": "Reset Password",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"token\": \"GET_FROM_SERVER_CONSOLE\",\n  \"newPassword\": \"NewPassword123!\"\n}"
                },
                "url": {
                    "raw": "{{mock_base_url}}/api/v1/auth/reset-password",
                    "host": [
                        "{{mock_base_url}}"
                    ],
                    "path": [
                        "api",
                        "v1",
                        "auth",
                        "reset-password"
                    ]
                }
            }
        },
        {
            "name": "Get Profile",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{access_token}}"
                    }
                ],
                "url": {
                    "raw": "{{mock_base_url}}/api/v1/auth/profile",
                    "host": [
                        "{{mock_base_url}}"
                    ],
                    "path": [
                        "api",
                        "v1",
                        "auth",
                        "profile"
                    ]
                }
            }
        },
        {
            "name": "Get Profile - No Token",
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "{{mock_base_url}}/api/v1/auth/profile",
                    "host": [
                        "{{mock_base_url}}"
                    ],
                    "path": [
                        "api",
                        "v1",
                        "auth",
                        "profile"
                    ]
                }
            }
        },
        {
            "name": "Logout",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{access_token}}"
                    }
                ],
                "url": {
                    "raw": "{{mock_base_url}}/api/v1/auth/logout",
                    "host": [
                        "{{mock_base_url}}"
                    ],
                    "path": [
                        "api",
                        "v1",
                        "auth",
                        "logout"
                    ]
                }
            }
        }
    ],
    "variable": [
        {
            "key": "mock_base_url",
            "value": "http://localhost:3001"
        }
    ]
}